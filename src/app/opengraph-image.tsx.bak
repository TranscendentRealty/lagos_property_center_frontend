import { ImageResponse } from 'next/og'

export const runtime = 'edge'
export const alt = 'Transcendent Realty - Trending Property'
export const size = { width: 900, height: 1200 }
export const contentType = 'image/png'

export default async function Image() {
  // 1. Fetch your #1 trending active listing from your database
  const trendingListing = await fetch(`${process.env.NEXT_PUBLIC_BACKEND_API_URL}/api/v1/pages/homepage`).then(res => res.json())

  // 2. Get the R2 image URL
  const trendingProperty = trendingListing.propertiesOfTheWeek?.[0] || null;

    // trendingProperty?.photos.sort((a : string, b : string) => {
    //     return a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' });
    // });

  const trendingImageUrl = trendingProperty?.photos?.[0] || 'https://media.transcendentrealty.com/og-transcendent-realty.png'; // Fallback to a default image if no photos are available

  // 3. Next.js dynamically composites this HTML/CSS into a PNG image on the fly!
  return new ImageResponse(
    (
      <div
        style={{
          width: '100%',
          height: '100%',
          display: 'flex',
          flexDirection: 'column',
          justifyContent: 'flex-end',
          backgroundImage: `url(${trendingImageUrl})`,
          backgroundSize: 'cover',
        }}
      >
        {/* Dynamic Overlay */}
        <div style={{ background: 'rgba(0,0,0,0.7)', padding: '40px', display: 'flex', flexDirection: 'column' }}>
          <h1 style={{ color: 'white', fontSize: 60, margin: 0 }}>Transcendent Realty</h1>
          <h2 style={{ color: '#D8FCE3', fontSize: 40, margin: 0 }}>
            Trending: {trendingListing.location} • {trendingListing.price}
          </h2>
        </div>
      </div>
    ),
    { ...size }
  )
}